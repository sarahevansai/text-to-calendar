# ============================================
# TEXT-TO-CALENDAR — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# See README.md for setup instructions for each service

# ---- App Config ----
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
# For production: BASE_URL=https://your-app.vercel.app

# ---- Anthropic (Claude) ----
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Twilio ----
# Get these at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# Set to 'true' during local development (skips Twilio signature validation)
SKIP_TWILIO_VALIDATION=true

# ---- Google OAuth ----
# Create credentials at: https://console.cloud.google.com/
# OAuth 2.0 Client ID (Web Application type)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# For production: GOOGLE_REDIRECT_URI=https://your-app.vercel.app/auth/google/callback

# ---- Database ----
# For local dev: leave as default (uses data/db.json)
# For production on Vercel: use a Supabase or PlanetScale URL
# DB_PATH=./data/db.json  (default — no need to set for local)

# ---- Session Secret ----
# Any random string — used to sign session cookies
SESSION_SECRET=change-me-to-something-random-and-long
